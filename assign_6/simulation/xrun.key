# Restoring simulation environment...
input -quiet .reinvoke.sim
file delete .reinvoke.sim
probe -create -shm tb_cdc.u_sync_syn1.async_in tb_cdc.u_sync_syn1.clk tb_cdc.u_sync_syn1.reset_n tb_cdc.u_sync_syn1.resolving tb_cdc.u_sync_syn1.sync_ff1 tb_cdc.u_sync_syn1.sync_out tb_cdc.u_sync_syn1.sync_out_resolved tb_cdc.u_sync_syn2.async_in tb_cdc.u_sync_syn2.clk tb_cdc.u_sync_syn2.reset_n tb_cdc.u_sync_syn2.resolving tb_cdc.u_sync_syn2.sync_ff1 tb_cdc.u_sync_syn2.sync_out tb_cdc.u_sync_syn2.sync_out_resolved
run
exit
